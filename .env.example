# LLM (llama.cpp server)
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=qwen3.5-4b
LLM_API_KEY=not-needed
LLM_MAX_TOKENS=256

# STT (faster-whisper)
WHISPER_MODEL=small.en
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# TTS (Piper)
PIPER_VOICE_PATH=models/piper/en_GB-northern_english_male-medium.onnx

# VAD (silero)
VAD_THRESHOLD=0.5
VAD_MIN_SILENCE_MS=800

# Robot
REACHY_HOST=localhost

# Paths
MODELS_DIR=models
LOGS_DIR=logs
